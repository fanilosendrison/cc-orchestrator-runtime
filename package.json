    "typecheck": "tsc --noEmit",
    "changelog": "git-cliff --output CHANGELOG.md"
  },
  "dependencies": {
    "zod": "^3.22.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
